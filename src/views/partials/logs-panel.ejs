<div class="panel" id="tab-logs">
  <div class="filters">
    <div class="filter-group">
      <label>From</label>
      <input type="date" id="log-from">
    </div>
    <div class="filter-group">
      <label>To</label>
      <input type="date" id="log-to">
    </div>
    <div class="filter-group">
      <label>Level</label>
      <select id="log-level">
        <option value="ALL">All Levels</option>
        <option value="TRACE">TRACE</option>
        <option value="DEBUG">DEBUG</option>
        <option value="INFO">INFO</option>
        <option value="WARN">WARN</option>
        <option value="ERROR">ERROR</option>
        <option value="FATAL">FATAL</option>
      </select>
    </div>
    <div class="filter-group">
      <label>Keyword (FTS)</label>
      <input type="search" id="log-q" placeholder='e.g. "request failed"'>
    </div>
    <div class="filter-group">
      <label>Per page</label>
      <select id="log-limit">
        <option value="100">100</option>
        <option value="200" selected>200</option>
        <option value="500">500</option>
      </select>
    </div>
    <button class="btn btn-primary" onclick="searchLogs(1)">Search</button>
    <button class="btn btn-ghost" onclick="resetFilters('log')">Reset</button>
  </div>

  <div class="logs-header">
    <h3>Log Entries</h3>
    <div class="badge" id="logCount">–</div>
    <div style="margin-left:auto; display:flex; gap:8px; align-items:center">
      <span id="logPageInfo" style="font-size:12px;color:var(--text-muted)"></span>
      <button class="btn btn-ghost" id="logPrev" onclick="changePage(-1)" disabled>← Prev</button>
      <button class="btn btn-ghost" id="logNext" onclick="changePage(1)" disabled>Next →</button>
    </div>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Level</th>
          <th>Method</th>
          <th>Status</th>
          <th style="text-align:right">RT (ms)</th>
          <th>URL</th>
          <th style="width:100%">Message</th>
        </tr>
      </thead>
      <tbody id="logTable">
        <tr>
          <td colspan="7" class="empty">
            <div class="spinner"></div>Loading…
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
