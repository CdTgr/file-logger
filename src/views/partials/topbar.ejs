<div class="topbar">
  <div class="logo">File<span>Logger</span></div>
  <div class="filter-group">
    <label>Log File</label>
    <select id="fileSelect">
      <option value="">All files</option>
      <% files.forEach(function(f) { %>
        <option value="<%= f %>" <%=f===selectedFile ? 'selected' : '' %>><%= f %>
        </option>
        <% }); %>
    </select>
  </div>
  <div class="topbar-spacer"></div>
  <button class="btn btn-ghost" id="ingestBtn" onclick="triggerIngest()">Ingest</button>
  <button class="btn btn-ghost" id="downloadBtn" onclick="downloadLogFile()"
    style="<%= selectedFile ? '' : 'display:none' %>">Download</button>
  <div id="dbStatus" style="font-size:12px; color:var(--text-muted)">Loading…</div>
</div>
